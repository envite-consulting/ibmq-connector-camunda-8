{
  "id": "qaoa-sidecar-error-form",
  "type": "default",
  "schemaVersion": 12,
  "components": [
    {
      "type": "textfield",
      "key": "sidecarUrl",
      "label": "Sidecar URL",
      "description": "The URL that was called. Verify the sidecar is running and reachable at this address.",
      "readonly": true
    },
    {
      "type": "number",
      "key": "iteration",
      "label": "Failed at iteration",
      "description": "SPSA iteration at which the sidecar call failed (0 = first iteration).",
      "readonly": true
    }
  ]
}
