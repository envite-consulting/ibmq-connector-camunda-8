{
  "id": "qaoa-result-form",
  "type": "default",
  "schemaVersion": 12,
  "components": [
    {
      "type": "textfield",
      "key": "bestPartition",
      "label": "Best Partition",
      "description": "Bitstring encoding the optimal node partition found. Each character is a node: '0' = partition A, '1' = partition B. E.g. '1010' puts nodes 0,2 in B and nodes 1,3 in A.",
      "readonly": true
    },
    {
      "type": "number",
      "key": "objectiveValue",
      "label": "Best Cut Weight",
      "description": "Max-Cut weight of the best partition found (higher is better). Reported as a negative value internally by the optimizer.",
      "readonly": true
    },
    {
      "type": "number",
      "key": "iteration",
      "label": "Iterations",
      "description": "Last BPMN loop iteration index (0 = first iteration). Total IBM Quantum jobs executed equals this value plus one.",
      "readonly": true
    },
    {
      "type": "textfield",
      "key": "convergenceReason",
      "label": "Convergence Reason",
      "description": "\"converged\": optimizer reached a stable solution. \"max_iterations\": stopped at the iteration cap — consider increasing Max Iterations or adjusting QAOA depth.",
      "readonly": true
    },
    {
      "type": "separator"
    },
    {
      "type": "textfield",
      "key": "ibmqResult.resultUrl",
      "label": "IBM Quantum Job URL",
      "description": "Link to the last IBM Quantum job in the IBM Quantum UI.",
      "readonly": true
    }
  ]
}
