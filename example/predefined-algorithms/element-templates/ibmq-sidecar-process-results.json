{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "IBM Quantum: Process Results",
  "id": "de.envite.ibmq-sidecar.process-results",
  "description": "Calls the quantum algorithm sidecar to post-process raw IBM Quantum measurement data into a classical answer (POST /process-results). Part of the IBM Quantum Algorithm Accelerator pattern — requires the IBM Quantum Connector.",
  "version": 1,
  "documentationRef": "https://github.com/envite/ibmq-connector-camunda-8/blob/main/docs/use-predefined-algorithms.md",
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  },
  "appliesTo": ["bpmn:ServiceTask"],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    { "id": "sidecar",    "label": "Algorithm Sidecar" },
    { "id": "algorithm",  "label": "Algorithm" },
    { "id": "output",     "label": "Output Mapping" },
    { "id": "error",      "label": "Error Handling" }
  ],
  "properties": [
    {
      "type": "Hidden",
      "value": "io.camunda:http-json:1",
      "binding": { "type": "zeebe:taskDefinition", "property": "type" }
    },

    {
      "label": "Process Results URL",
      "description": "Full URL of the sidecar's <code>/process-results</code> endpoint. The default FEEL expression appends the path to the <code>sidecarUrl</code> process variable.",
      "group": "sidecar",
      "type": "String",
      "feel": "optional",
      "value": "= sidecarUrl + \"/process-results\"",
      "binding": { "type": "zeebe:input", "name": "url" },
      "constraints": { "notEmpty": true }
    },
    {
      "type": "Hidden",
      "value": "= \"POST\"",
      "binding": { "type": "zeebe:input", "name": "method" }
    },
    {
      "type": "Hidden",
      "value": "= {\"Content-Type\": \"application/json\"}",
      "binding": { "type": "zeebe:input", "name": "headers" }
    },

    {
      "label": "Request Body (FEEL)",
      "description": "FEEL object sent as the sidecar request body. Must include <code>algorithm</code>, the original <code>problem</code>, and <code>results</code> — the raw Qiskit Runtime payload from <code>ibmqResult.result</code> as set by the IBM Quantum Connector's GET_JOB_RESULT result expression.",
      "group": "algorithm",
      "type": "Text",
      "feel": "required",
      "value": "= {algorithm: \"grover\", problem: problem, results: ibmqResult.result}",
      "binding": { "type": "zeebe:input", "name": "body" },
      "constraints": { "notEmpty": true }
    },

    {
      "label": "Result Variable",
      "description": "Process variable to store the raw sidecar HTTP response",
      "group": "output",
      "type": "String",
      "value": "processResultsOutput",
      "binding": { "type": "zeebe:taskHeader", "key": "resultVariable" }
    },
    {
      "label": "Result Expression",
      "description": "Maps the sidecar response to the <code>classicalResult</code> process variable. The sidecar returns an object with <code>answer</code>, <code>found</code>, <code>confidence</code>, and <code>details</code>.",
      "group": "output",
      "type": "Text",
      "feel": "required",
      "value": "= {classicalResult: response.body}",
      "binding": { "type": "zeebe:taskHeader", "key": "resultExpression" }
    },

    {
      "label": "Error Expression",
      "description": "FEEL expression to map sidecar HTTP errors to BPMN errors",
      "group": "error",
      "type": "Text",
      "feel": "required",
      "optional": true,
      "binding": { "type": "zeebe:taskHeader", "key": "errorExpression" }
    }
  ]
}
