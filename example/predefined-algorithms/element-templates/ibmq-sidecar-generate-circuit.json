{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "IBM Quantum: Generate Circuit",
  "id": "de.envite.ibmq-sidecar.generate-circuit",
  "description": "Calls the quantum algorithm sidecar to translate classical problem parameters into an executable quantum circuit (POST /generate-circuit). Part of the IBM Quantum Algorithm Accelerator pattern — requires the IBM Quantum Connector.",
  "version": 1,
  "documentationRef": "https://github.com/envite/ibmq-connector-camunda-8/blob/main/docs/use-predefined-algorithms.md",
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  },
  "appliesTo": ["bpmn:ServiceTask"],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    { "id": "sidecar",    "label": "Algorithm Sidecar" },
    { "id": "algorithm",  "label": "Algorithm" },
    { "id": "output",     "label": "Output Mapping" },
    { "id": "error",      "label": "Error Handling" }
  ],
  "properties": [
    {
      "type": "Hidden",
      "value": "io.camunda:http-json:1",
      "binding": { "type": "zeebe:taskDefinition", "property": "type" }
    },

    {
      "label": "Generate Circuit URL",
      "description": "Full URL of the sidecar's <code>/generate-circuit</code> endpoint. The default FEEL expression appends the path to the <code>sidecarUrl</code> process variable. Store the base URL as a Camunda secret and map it to <code>sidecarUrl</code>.",
      "group": "sidecar",
      "type": "String",
      "feel": "optional",
      "value": "= sidecarUrl + \"/generate-circuit\"",
      "binding": { "type": "zeebe:input", "name": "url" },
      "constraints": { "notEmpty": true }
    },
    {
      "type": "Hidden",
      "value": "= \"POST\"",
      "binding": { "type": "zeebe:input", "name": "method" }
    },
    {
      "type": "Hidden",
      "value": "= {\"Content-Type\": \"application/json\"}",
      "binding": { "type": "zeebe:input", "name": "headers" }
    },

    {
      "label": "Request Body (FEEL)",
      "description": "FEEL object sent as the sidecar request body. Must include <code>algorithm</code> (string) and <code>problem</code> (object with classical problem parameters). The <code>problem</code> process variable is typically populated by a start form.",
      "group": "algorithm",
      "type": "Text",
      "feel": "required",
      "value": "= {algorithm: \"grover\", problem: problem}",
      "binding": { "type": "zeebe:input", "name": "body" },
      "constraints": { "notEmpty": true }
    },

    {
      "label": "Result Variable",
      "description": "Process variable to store the raw sidecar HTTP response",
      "group": "output",
      "type": "String",
      "value": "generateCircuitResult",
      "binding": { "type": "zeebe:taskHeader", "key": "resultVariable" }
    },
    {
      "label": "Result Expression",
      "description": "Maps the sidecar response to process variables consumed by the IBM Quantum Connector. For OpenQASM mode the sidecar returns <code>circuit</code> and <code>shots</code>; for Direct Params mode replace with <code>{params: response.body.params}</code>.",
      "group": "output",
      "type": "Text",
      "feel": "required",
      "value": "= {circuit: response.body.circuit, shots: response.body.shots}",
      "binding": { "type": "zeebe:taskHeader", "key": "resultExpression" }
    },

    {
      "label": "Error Expression",
      "description": "FEEL expression to map sidecar HTTP errors to BPMN errors",
      "group": "error",
      "type": "Text",
      "feel": "required",
      "optional": true,
      "binding": { "type": "zeebe:taskHeader", "key": "errorExpression" }
    }
  ]
}
