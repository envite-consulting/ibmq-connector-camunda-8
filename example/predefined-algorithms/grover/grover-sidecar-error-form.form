{
  "id": "grover-sidecar-error-form",
  "type": "default",
  "schemaVersion": 12,
  "components": [
    {
      "type": "textfield",
      "key": "sidecarUrl",
      "label": "Sidecar URL",
      "description": "The URL that was called. Check that the sidecar is running and reachable at this address.",
      "readonly": true
    },
    {
      "type": "textfield",
      "key": "sidecarErrorMessage",
      "label": "Error details",
      "description": "HTTP status and error message, if available.",
      "readonly": true
    }
  ]
}
