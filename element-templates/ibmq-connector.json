{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "IBM Quantum Connector",
  "id": "de.envite.ibmq-connector",
  "description": "Execute quantum circuits on IBM Quantum via the Qiskit Runtime REST API.",
  "version": 1,
  "documentationRef": "https://github.com/envite-consulting/ibmq-connector-camunda-8",
  "category": {
    "id": "connectors",
    "name": "Connectors"
  },
  "icon": {
    "contents": "data:image/svg+xml;base64,"
  },
  "appliesTo": [
    "bpmn:Task",
    "bpmn:ServiceTask",
    "bpmn:UserTask",
    "bpmn:SendTask",
    "bpmn:ReceiveTask",
    "bpmn:ManualTask",
    "bpmn:BusinessRuleTask",
    "bpmn:ScriptTask"
  ],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    { "id": "operation",      "label": "Operation" },
    { "id": "ibmq",           "label": "IBMQ" },
    { "id": "circuit",        "label": "Quantum Circuit" },
    { "id": "execution",      "label": "Execution" },
    { "id": "output",         "label": "Output Mapping" },
    { "id": "error",          "label": "Error Handling" }
  ],
  "properties": [
    {
      "type": "Hidden",
      "value": "de.envite:ibmq-connector:1",
      "binding": { "type": "zeebe:taskDefinition", "property": "type" }
    },

    {
      "id": "operationMode",
      "label": "Operation",
      "description": "Choose <em>Submit Job</em> to queue a new quantum job. Choose <em>Get Job Result</em> to check the status of a previously submitted job — use this inside a BPMN polling loop with a timer to avoid long-running connector threads.",
      "group": "operation",
      "type": "Dropdown",
      "value": "SUBMIT_JOB",
      "choices": [
        { "name": "Submit Job",      "value": "SUBMIT_JOB" },
        { "name": "Get Job Result",  "value": "GET_JOB_RESULT" }
      ],
      "binding": { "type": "zeebe:input", "name": "operationMode" }
    },

    {
      "label": "IBMQ API Key",
      "description": "Use a Camunda secret: <code>{{secrets.IBMQ_API_KEY}}</code>",
      "group": "ibmq",
      "type": "String",
      "feel": "optional",
      "binding": { "type": "zeebe:input", "name": "apiKey" },
      "constraints": { "notEmpty": true }
    },
    {
      "label": "IBMQ URL",
      "description": "IBMQ endpoint, e.g., https://quantum.cloud.ibm.com/api",
      "group": "ibmq",
      "type": "String",
      "value": "https://quantum.cloud.ibm.com/api",
      "feel": "optional",
      "binding": { "type": "zeebe:input", "name": "ibmqUrl" }
    },
    {
      "label": "IBMQ Instance CRN",
      "description": "IBM Quantum instance Cloud Resource Name (CRN). Find it in IBM Cloud → Resource list → your Quantum Computing instance → Details.",
      "group": "ibmq",
      "type": "String",
      "feel": "optional",
      "binding": { "type": "zeebe:input", "name": "ibmqInstance" },
      "constraints": { "notEmpty": true }
    },

    {
      "label": "Job ID",
      "description": "ID of the previously submitted IBM Quantum job to check",
      "group": "ibmq",
      "type": "String",
      "feel": "optional",
      "binding": { "type": "zeebe:input", "name": "jobId" },
      "constraints": { "notEmpty": true },
      "condition": { "property": "operationMode", "equals": "GET_JOB_RESULT" }
    },

    {
      "label": "IBMQ Backend",
      "description": "Target quantum computer for the execution",
      "group": "ibmq",
      "type": "String",
      "feel": "optional",
      "binding": { "type": "zeebe:input", "name": "backend" },
      "constraints": { "notEmpty": true },
      "condition": { "property": "operationMode", "equals": "SUBMIT_JOB" }
    },

    {
      "id": "programId",
      "label": "Program ID",
      "description": "Qiskit Runtime program to execute. Use Sampler to directly execute <em>OpenQASM</em> quantum circuits.",
      "group": "circuit",
      "type": "Dropdown",
      "value": "sampler",
      "choices": [
        { "name": "Sampler",   "value": "sampler" },
        { "name": "Estimator", "value": "estimator" }
      ],
      "binding": { "type": "zeebe:input", "name": "programId" },
      "constraints": { "notEmpty": true },
      "condition": { "property": "operationMode", "equals": "SUBMIT_JOB" }
    },
    {
      "id": "circuitInputMode",
      "label": "Circuit Input Mode",
      "description": "How the quantum circuit is supplied. Use <em>OpenQASM</em> to enter a circuit string directly, or <em>Direct Params</em> for full control over the Qiskit Runtime job params.",
      "group": "circuit",
      "type": "Dropdown",
      "value": "OPEN_QASM",
      "choices": [
        { "name": "OpenQASM (2 or 3)",    "value": "OPEN_QASM" },
        { "name": "Direct Params (JSON)", "value": "DIRECT_PARAMS" }
      ],
      "binding": { "type": "zeebe:input", "name": "CircuitInputMode" },
      "condition": {
        "allMatch": [
          { "property": "operationMode", "equals": "SUBMIT_JOB" },
          { "property": "programId",     "equals": "sampler"    }
        ]
      }
    },
    {
      "label": "Quantum Circuit (OpenQASM)",
      "description": "OpenQASM 3 circuit using native basis gates (x, sx, rz, cx). The REST API does not transpile — non-native gates like h must be pre-decomposed, e.g. h ≡ rz(π/2); sx; rz(π/2).",
      "group": "circuit",
      "type": "Text",
      "feel": "optional",
      "binding": { "type": "zeebe:input", "name": "circuit" },
      "constraints": { "notEmpty": true },
      "condition": {
        "allMatch": [
          { "property": "programId",       "equals": "sampler"    },
          { "property": "circuitInputMode", "equals": "OPEN_QASM" }
        ]
      }
    },
    {
      "label": "OpenQASM Version",
      "description": "Version of the supplied circuit. OpenQASM 3 is preferred; most backends also accept OpenQASM 2.",
      "group": "circuit",
      "type": "Dropdown",
      "value": "3",
      "choices": [
        { "name": "OpenQASM 3 (recommended)", "value": "3" },
        { "name": "OpenQASM 2",               "value": "2" }
      ],
      "binding": { "type": "zeebe:input", "name": "qasmVersion" },
      "condition": {
        "allMatch": [
          { "property": "programId",       "equals": "sampler"    },
          { "property": "circuitInputMode", "equals": "OPEN_QASM" }
        ]
      }
    },
    {
      "label": "Shots",
      "description": "Number of circuit repetitions",
      "group": "circuit",
      "type": "Number",
      "value": 1024,
      "binding": { "type": "zeebe:input", "name": "shots" },
      "condition": {
        "allMatch": [
          { "property": "programId",       "equals": "sampler"    },
          { "property": "circuitInputMode", "equals": "OPEN_QASM" }
        ]
      }
    },
    {
      "label": "Params (JSON)",
      "description": "Full Qiskit Runtime V2 params as a JSON string, e.g. {\"version\": 2, \"pubs\": [[\"&lt;circuit&gt;\", null, 1024]]}. See <a href=\"https://quantum.cloud.ibm.com/docs/guides/primitives-rest-api\">Primitives with REST API</a> for details.",
      "group": "circuit",
      "type": "Text",
      "feel": "optional",
      "binding": { "type": "zeebe:input", "name": "params" },
      "constraints": { "notEmpty": true },
      "condition": {
        "allMatch": [
          { "property": "operationMode", "equals": "SUBMIT_JOB" },
          { "property": "programId",     "equals": "estimator"  }
        ]
      }
    },
    {
      "label": "Params (JSON)",
      "description": "Full Qiskit Runtime V2 params as a JSON string, e.g. {\"version\": 2, \"pubs\": [[\"&lt;circuit&gt;\", null, 1024]]}. See <a href=\"https://quantum.cloud.ibm.com/docs/guides/primitives-rest-api\">Primitives with REST API</a> for details.",
      "group": "circuit",
      "type": "Text",
      "feel": "optional",
      "binding": { "type": "zeebe:input", "name": "params" },
      "constraints": { "notEmpty": true },
      "condition": {
        "allMatch": [
          { "property": "operationMode",    "equals": "SUBMIT_JOB"    },
          { "property": "programId",        "equals": "sampler"       },
          { "property": "circuitInputMode",  "equals": "DIRECT_PARAMS" }
        ]
      }
    },

    {
      "label": "Wait for Result",
      "description": "Poll until the job reaches a terminal state before completing the task. Disable this and use <em>Get Job Result</em> in a BPMN timer loop to avoid HTTP/2 inactivity timeouts on long-running quantum jobs.",
      "group": "execution",
      "type": "Boolean",
      "value": "true",
      "binding": { "type": "zeebe:input", "name": "waitForResult" },
      "condition": { "property": "operationMode", "equals": "SUBMIT_JOB" }
    },
    {
      "label": "Timeout (seconds)",
      "description": "Maximum time to wait for a result",
      "group": "execution",
      "type": "Number",
      "value": 300,
      "binding": { "type": "zeebe:input", "name": "timeoutSeconds" },
      "condition": { "property": "operationMode", "equals": "SUBMIT_JOB" }
    },
    {
      "label": "Poll Interval (seconds)",
      "description": "How often to check the job status",
      "group": "execution",
      "type": "Number",
      "value": 5,
      "binding": { "type": "zeebe:input", "name": "pollIntervalSeconds" },
      "condition": { "property": "operationMode", "equals": "SUBMIT_JOB" }
    },

    {
      "label": "Result Variable",
      "description": "Name of the process variable to store the connector result",
      "group": "output",
      "type": "String",
      "value": "ibmqResult",
      "binding": { "type": "zeebe:taskHeader", "key": "resultVariable" }
    },
    {
      "label": "Result Expression",
      "description": "FEEL expression to map the result into process variables",
      "group": "output",
      "type": "Text",
      "feel": "required",
      "value": "= {jobId: response.jobId, status: response.status, result: response.result}",
      "binding": { "type": "zeebe:taskHeader", "key": "resultExpression" }
    },

    {
      "label": "Error Expression",
      "description": "FEEL expression to handle connector errors as BPMN errors",
      "group": "error",
      "type": "Text",
      "feel": "required",
      "optional": true,
      "binding": { "type": "zeebe:taskHeader", "key": "errorExpression" }
    }
  ]
}
